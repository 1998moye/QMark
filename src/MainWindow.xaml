<Window x:Class="MarkdownEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MarkdownEditor"
        mc:Ignorable="d"
        Title="QMark"
        Icon="icons/icon_32.png"
        WindowStartupLocation="CenterScreen"
        Height="780" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing"
        MouseLeftButtonDown="TitleBar_MouseDown"
        StateChanged="Window_StateChanged"
        SourceInitialized="Window_SourceInitialized">
    <Window.CommandBindings>
        <CommandBinding Command="New" Executed="NewFile" />
        <CommandBinding Command="Open" Executed="OpenFile" />
        <CommandBinding Command="Save" Executed="SaveFile" />
        <CommandBinding Command="SaveAs" Executed="SaveFileAs" />
        <CommandBinding Command="Undo" Executed="Undo" CanExecute="UndoCanExecute" />
        <CommandBinding Command="Redo" Executed="Redo" CanExecute="RedoCanExecute" />
        <CommandBinding Command="local:MainWindow.BoldCommand" Executed="FormatBold" />
        <CommandBinding Command="local:MainWindow.ItalicCommand" Executed="FormatItalic" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="New" />
        <KeyBinding Key="O" Modifiers="Control" Command="Open" />
        <KeyBinding Key="S" Modifiers="Control" Command="Save" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="SaveAs" />
        <KeyBinding Key="Z" Modifiers="Control" Command="Undo" />
        <KeyBinding Key="Y" Modifiers="Control" Command="Redo" />
        <KeyBinding Key="B" Modifiers="Control" Command="local:MainWindow.BoldCommand" />
        <KeyBinding Key="I" Modifiers="Control" Command="local:MainWindow.ItalicCommand" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Tag-to-Visibility converter: if Tag is "file", collapse -->
        <local:TagToVisibilityConverter x:Key="TagVisConverter" />
        <!-- Color Palette -->
        <Color x:Key="AccentColor">#2563eb</Color>
        <Color x:Key="AccentHoverColor">#1d4ed8</Color>
        <Color x:Key="BgPage">#f0f2f5</Color>
        <Color x:Key="BgSurface">#ffffff</Color>
        <Color x:Key="BgToolbar">#ffffff</Color>
        <Color x:Key="BgTitleBar">#1a1a2e</Color>
        <Color x:Key="TextPrimary">#1a1a2e</Color>
        <Color x:Key="TextSecondary">#6b7280</Color>
        <Color x:Key="TextOnDark">#ffffff</Color>
        <Color x:Key="BorderColor">#e5e7eb</Color>
        <Color x:Key="HoverBg">#f3f4f6</Color>
        <Color x:Key="ActiveBg">#e8ecf4</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="BgPageBrush" Color="{StaticResource BgPage}" />
        <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
        <SolidColorBrush x:Key="BgToolbarBrush" Color="{StaticResource BgToolbar}" />
        <SolidColorBrush x:Key="BgTitleBarBrush" Color="{StaticResource BgTitleBar}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="TextOnDarkBrush" Color="{StaticResource TextOnDark}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource HoverBg}" />
        <SolidColorBrush x:Key="ActiveBgBrush" Color="{StaticResource ActiveBg}" />

        <!-- Drop shadow for popups -->
        <DropShadowEffect x:Key="Shadow" BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#000" />

        <!-- Modern Button Style -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="4" BorderThickness="0">
                            <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ActiveBgBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="cp" Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Buttons -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource TextOnDarkBrush}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2a2a4e" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3a3a5e" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e81123" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#f1707a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Buttons (Light toolbar background) -->
        <Style x:Key="WinBtnLight" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e5e7eb" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#d1d5db" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnLight" TargetType="Button" BasedOn="{StaticResource WinBtnLight}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#f1707a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Format Button -->
        <Style x:Key="FormatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="2" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ActiveBgBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mode Toggle Button -->
        <Style x:Key="ModeBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ComboBox Style -->
        <Style x:Key="FlatCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource HoverBgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderThickness="0"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="5" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <ContentPresenter x:Name="content"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="arrow" Text="▼" FontSize="6"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ActiveBgBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ActiveBgBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="popup" Placement="Bottom" StaysOpen="False"
                                   AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   VerticalOffset="4" HorizontalOffset="0">
                                <Border Background="White" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                        Padding="4" Effect="{StaticResource Shadow}">
                                    <ScrollViewer MaxHeight="200" Style="{DynamicResource FlatScrollViewer}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ComboBoxItem Style -->
        <Style x:Key="FlatComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="#d0d0d0" CornerRadius="10" BorderThickness="0" Width="36" Height="20">
                            <Border x:Name="thumb" Width="16" Height="16" CornerRadius="8"
                                    Background="White" HorizontalAlignment="Left" Margin="2,0"
                                    Effect="{StaticResource Shadow}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ToolTip Style -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="White" CornerRadius="5"
                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource Shadow}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ScrollBar Style -->
        <Style x:Key="FlatScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border x:Name="thumb" Background="#d0d0d0" CornerRadius="4" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumb" Property="Background" Value="#b0b0b0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit ScrollBar: applies to all ScrollBars (editor, listboxes, etc.) -->
        <Style TargetType="ScrollBar" BasedOn="{StaticResource FlatScrollBar}" />

        <!-- Flat ScrollViewer Style -->
        <Style x:Key="FlatScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" CanContentScroll="True" />
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource FlatScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Popup Button (used in popups like theme manager) -->
        <Style x:Key="PopupBtn" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#e5e7eb" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#f3f4f6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#d1d5db" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e5e7eb" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu Bar Button -->
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator -->
        <Style x:Key="VSep" TargetType="Separator">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        </Style>

        <!-- Flat GridSplitter Style - nearly invisible, accent on hover -->
        <Style x:Key="FlatGridSplitter" TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeViewItem style: theme-aware selection, no default blue highlight -->
        <SolidColorBrush x:Key="TreeItemSelectedBg" Color="#e8ecf4" />
        <SolidColorBrush x:Key="TreeItemHoverBg" Color="#f3f4f6" />
        <SolidColorBrush x:Key="TreeItemSelectedText" Color="#1a1a2e" />
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="itemBd" Background="Transparent"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                    Margin="0,0,6,0">
                                <Grid ClipToBounds="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Width="12" Height="12" Margin="-2,0,0,0"
                                                  Visibility="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TagVisConverter}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="expBd" Background="Transparent" Width="12" Height="12">
                                                    <TextBlock x:Name="arrow" Text="▸" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="arrow" Property="Text" Value="▾" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header" Grid.Column="1"
                                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource TreeItemSelectedBg}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource TreeItemHoverBg}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inline edit TextBox style (for new file/dir name input in file tree) -->
        <Style x:Key="InlineEditBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#f8f9fa" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderBrush" Value="#e5e7eb" />
            <Setter Property="MaxWidth" Value="160" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource CtxMenuBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Chrome -->
    <Border x:Name="ChromeBorder" Background="{StaticResource BgPageBrush}" CornerRadius="10" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />  <!-- Title bar -->
                <RowDefinition Height="26" />  <!-- Menu bar -->
                <RowDefinition Height="32" />  <!-- Toolbar -->
                <RowDefinition Height="*" />   <!-- Content -->
                <RowDefinition Height="26" />  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════ Row 0: Title Bar ═══════ -->
            <Border x:Name="TitleBarBorder" Grid.Row="0" Background="{StaticResource BgTitleBarBrush}" CornerRadius="10,10,0,0" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                        <Image Source="icons/icon_16.png" Width="18" Height="18" />
                        <TextBlock Text="QMark" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextOnDarkBrush}" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="TitleFileName"
                               Text="未命名.md" Foreground="#888" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnMinimize" Style="{StaticResource WinBtn}" Click="MinimizeWindow" ToolTip="最小化">
                            <TextBlock Text="─" FontSize="14" />
                        </Button>
                        <Button x:Name="BtnMaximize" Style="{StaticResource WinBtn}" Click="MaximizeWindow" ToolTip="最大化">
                            <TextBlock x:Name="MaxIcon" Text="□" FontSize="12" FontWeight="Bold" />
                        </Button>
                        <Button x:Name="BtnClose" Style="{StaticResource CloseBtn}" Click="CloseWindow" ToolTip="关闭">
                            <TextBlock Text="✕" FontSize="13" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════ Row 1: Menu Bar ═══════ -->
            <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                <StackPanel Orientation="Horizontal" Margin="4,0">
                    <Button x:Name="MenuFile" Content="文件" Style="{StaticResource MenuBtn}" Click="MenuFile_Click" />
                    <Button x:Name="MenuEdit" Content="编辑" Style="{StaticResource MenuBtn}" Click="MenuEdit_Click" />
                    <Button x:Name="MenuInsert" Content="插入" Style="{StaticResource MenuBtn}" Click="MenuInsert_Click" />
                    <Button x:Name="MenuFormat" Content="格式" Style="{StaticResource MenuBtn}" Click="MenuFormat_Click" />
                    <Button x:Name="MenuView" Content="视图" Style="{StaticResource MenuBtn}" Click="MenuView_Click" />
                    <Button x:Name="MenuTheme" Content="主题" Style="{StaticResource MenuBtn}" Click="MenuTheme_Click" />
                </StackPanel>
            </Border>

            <!-- ═══════ Row 2: Compact Toolbar ═══════ -->
            <Border Grid.Row="2" Background="{StaticResource BgToolbarBrush}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: format buttons -->
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Margin="6,0">
                            <Button Command="New" Style="{StaticResource IconBtn}" ToolTip="新建文件 (Ctrl+N)">
                                <TextBlock Text="📄" FontSize="15" />
                            </Button>
                            <Button Command="Open" Style="{StaticResource IconBtn}" ToolTip="打开文件 (Ctrl+O)">
                                <TextBlock Text="📂" FontSize="15" />
                            </Button>
                            <Button Command="Save" Style="{StaticResource IconBtn}" ToolTip="保存 (Ctrl+S)">
                                <TextBlock Text="💾" FontSize="15" />
                            </Button>
                            <Button x:Name="BtnRecent" Style="{StaticResource IconBtn}" ToolTip="最近打开的文件"
                                    Click="BtnRecent_Click">
                                <TextBlock Text="📋" FontSize="15" />
                            </Button>
                            <Separator Style="{StaticResource VSep}" />
                            <Popup x:Name="RecentPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnRecent}"
                                   StaysOpen="False" AllowsTransparency="True"
                                   VerticalOffset="4" HorizontalOffset="0"
                                   PopupAnimation="Fade">
                                <Border x:Name="RecentPopupBorder" Background="White" CornerRadius="8"
                                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                        Padding="6" Effect="{StaticResource Shadow}"
                                        MaxHeight="300" Width="320">
                                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto"
                                                  Style="{StaticResource FlatScrollViewer}">
                                        <StackPanel x:Name="RecentListPanel" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <Separator Style="{StaticResource VSep}" />
                            <Button Command="Undo" Style="{StaticResource IconBtn}" ToolTip="撤销 (Ctrl+Z)">
                                <TextBlock Text="↩" FontSize="15" />
                            </Button>
                            <Button Command="Redo" Style="{StaticResource IconBtn}" ToolTip="重做 (Ctrl+Y)">
                                <TextBlock Text="↪" FontSize="15" />
                            </Button>
                            <Separator Style="{StaticResource VSep}" />
                            <Button x:Name="BtnBold" Click="FormatBold" Style="{StaticResource FormatBtn}" ToolTip="粗体 (Ctrl+B)" FontWeight="Bold">
                                <TextBlock Text="B" FontWeight="Bold" />
                            </Button>
                            <Button x:Name="BtnItalic" Click="FormatItalic" Style="{StaticResource FormatBtn}" ToolTip="斜体 (Ctrl+I)" FontStyle="Italic">
                                <TextBlock Text="I" FontStyle="Italic" />
                            </Button>
                            <Button x:Name="BtnStrike" Click="FormatStrike" Style="{StaticResource FormatBtn}" ToolTip="删除线">
                                <TextBlock Text="S" TextDecorations="Strikethrough" />
                            </Button>
                            <Button x:Name="BtnHeading" Click="FormatHeading" Style="{StaticResource FormatBtn}" ToolTip="标题" FontWeight="Bold" FontSize="14">
                                <TextBlock Text="H" />
                            </Button>
                            <Button x:Name="BtnCode" Click="FormatCode" Style="{StaticResource FormatBtn}" ToolTip="代码块" FontFamily="Consolas" FontSize="12">
                                <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" />
                            </Button>
                            <Separator Style="{StaticResource VSep}" />
                            <Button x:Name="BtnBulletList" Click="FormatBulletList" Style="{StaticResource FormatBtn}" ToolTip="无序列表">
                                <TextBlock Text="•" FontSize="15" />
                            </Button>
                            <Button x:Name="BtnNumberedList" Click="FormatNumberedList" Style="{StaticResource FormatBtn}" ToolTip="有序列表">
                                <TextBlock Text="1." FontSize="12" />
                            </Button>
                            <Button x:Name="BtnQuote" Click="FormatQuote" Style="{StaticResource FormatBtn}" ToolTip="引用">
                                <TextBlock Text="❝" FontSize="14" />
                            </Button>
                            <Separator Style="{StaticResource VSep}" />
                            <Button x:Name="BtnLink" Click="FormatLink" Style="{StaticResource FormatBtn}" ToolTip="插入链接">
                                <TextBlock Text="🔗" FontSize="13" />
                            </Button>
                            <Button x:Name="BtnImage" Click="FormatImage" Style="{StaticResource FormatBtn}" ToolTip="插入图片">
                                <TextBlock Text="🖼" FontSize="13" />
                            </Button>
                            <Button x:Name="BtnTable" Click="FormatTable" Style="{StaticResource FormatBtn}" ToolTip="插入表格">
                                <TextBlock Text="⊞" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right: view mode -->
                    <Border Grid.Column="1" Background="{DynamicResource HoverBgBrush}" CornerRadius="6" Padding="2" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ModeSource" Content="源码" GroupName="ViewMode"
                                         Style="{StaticResource ModeBtn}" Checked="SwitchViewMode" />
                            <RadioButton x:Name="ModeSplit" Content="分栏" GroupName="ViewMode"
                                         Style="{StaticResource ModeBtn}" Checked="SwitchViewMode" />
                            <RadioButton x:Name="ModePreview" Content="预览" GroupName="ViewMode"
                                         Style="{StaticResource ModeBtn}" Checked="SwitchViewMode" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════ Row 3: Content Area ═══════ -->
            <Grid Grid.Row="3" Margin="0" x:Name="ContentAreaGrid">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar panel (0 when collapsed) -->
                    <ColumnDefinition x:Name="ColSidebarPanel" Width="0" MinWidth="0" />
                    <!-- Sidebar splitter -->
                    <ColumnDefinition x:Name="ColSidebarSplitter" Width="0" />
                    <!-- Editor -->
                    <ColumnDefinition x:Name="ColEditor" Width="*" MinWidth="0" />
                    <!-- Editor/Preview splitter -->
                    <ColumnDefinition x:Name="ColSplitter" Width="Auto" />
                    <!-- Preview -->
                    <ColumnDefinition x:Name="ColPreview" Width="*" MinWidth="0" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar panel (no right border - GridSplitter itself is the divider) -->
                <Border x:Name="SidebarPanel" Grid.Column="0" Background="{StaticResource BgSurfaceBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Tab bar -->
                        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TabOutline" Grid.Column="0" Padding="8,8,8,6" Cursor="Hand"
                                        BorderThickness="0,0,0,2" BorderBrush="#2563eb"
                                        Background="Transparent" MouseDown="ShowOutlineTab">
                                    <TextBlock Text="📑 目录" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#2563eb" HorizontalAlignment="Center" />
                                </Border>
                                <Border x:Name="TabFiles" Grid.Column="1" Padding="8,8,8,6" Cursor="Hand"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                        Background="Transparent" MouseDown="ShowFilesTab">
                                    <TextBlock Text="📁 文件" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Outline tab content -->
                        <Grid Grid.Row="1" Grid.RowSpan="2" x:Name="OutlineContent" Visibility="Visible">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource FlatScrollViewer}">
                                <StackPanel x:Name="OutlinePanel" Margin="6,4,6,6" />
                            </ScrollViewer>
                        </Grid>
                        <!-- File list tab content -->
                        <Grid Grid.Row="1" Grid.RowSpan="2" x:Name="FilesContent" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="8,4,8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="FileTreeUpButton" Grid.Column="0"
                                            Style="{StaticResource MenuBtn}"
                                            ToolTip="切换到父级目录"
                                            Click="NavigateFileTreeUp">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- folder + up arrow: bold line-art, stroke bound to theme color -->
                                            <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                                  Data="M2,3 L8,3 L10,7 L22,7 L22,21 L2,21 Z M2,3 L2,7 M12,11 L12,17 M9,14 L12,11 L15,14"
                                                  Stroke="{DynamicResource TextPrimaryBrush}"
                                                  StrokeThickness="1"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent" />
                                            <TextBlock Text="上一级" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="FileTreeBackButton" Grid.Column="2"
                                            Style="{StaticResource MenuBtn}"
                                            ToolTip="切换到文件所在目录"
                                            Click="NavigateFileTreeBack"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                                  Data="M12,2 L12,8 M12,16 L12,22 M2,12 L8,12 M16,12 L22,12 M12,10 L14,12 L12,14 L10,12 Z"
                                                  Stroke="{DynamicResource TextPrimaryBrush}"
                                                  StrokeThickness="1.2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent" />
                                            <TextBlock Text="文件层" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock x:Name="FilesDirText" Grid.Column="4" FontSize="10"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                            <TreeView x:Name="FileTreeView" Grid.Row="1"
                                      Background="Transparent" BorderThickness="0"
                                      HorizontalContentAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.CanContentScroll="False" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Sidebar splitter -->
                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1"
                              Style="{StaticResource FlatGridSplitter}"
                              ResizeBehavior="PreviousAndNext" IsEnabled="False" />

                <!-- Editor panel -->
                <Border Grid.Column="2" Background="{StaticResource BgSurfaceBrush}" Margin="0">
                    <wv2:WebView2 x:Name="EditorWebView" Margin="0" />
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="3"
                              Style="{StaticResource FlatGridSplitter}"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Preview panel -->
                <Border Grid.Column="4" Background="{StaticResource BgSurfaceBrush}" Margin="0">
                    <wv2:WebView2 x:Name="PreviewWebView" Margin="0" />
                </Border>

                <!-- Floating sidebar toggle: created programmatically as transparent overlay Window -->
            </Grid>

            <!-- ═══════ Row 4: Status Bar ═══════ -->
            <Border x:Name="StatusBarBorder" Grid.Row="4" Background="{StaticResource BgSurfaceBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                    CornerRadius="0,0,10,10">
                <Grid Margin="14,0,6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StatusText" Text="就绪"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" x:Name="WordCountText" Text="行 0 · 字 0 · 字符 0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Hidden controls (referenced by C# code) -->

            <Grid Visibility="Collapsed">
                <ComboBox x:Name="ThemeSelector" SelectionChanged="ThemeSelector_SelectionChanged" />
                <Button x:Name="BtnThemeManage" Click="OpenThemeManager" />
                <ToggleButton x:Name="ClickToEditToggle" Checked="ClickToEditToggled" Unchecked="ClickToEditToggled" />
            </Grid>

            <!-- Theme management popup (must be in visible tree, not collapsed) -->
            <Popup x:Name="ThemePopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                   VerticalOffset="4" PopupAnimation="Fade">
                <Border Background="White" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}" Padding="0"
                        Effect="{StaticResource Shadow}" Width="240" MaxHeight="420">
                    <StackPanel>
                        <TextBlock Text="管理可用主题" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="14,12,14,8" />
                        <TextBox x:Name="ThemeSearchBox"
                                 TextChanged="ThemeSearch_TextChanged"
                                 Margin="12,0,12,8" Padding="8,5"
                                 FontSize="13" BorderThickness="1"
                                 BorderBrush="#e5e7eb" Background="#f8f9fa"
                                 Foreground="#333" />
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300"
                                      Style="{DynamicResource FlatScrollViewer}">
                            <StackPanel x:Name="ThemeListPanel" Margin="8,6,8,6" />
                        </ScrollViewer>
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,12">
                            <Button Content="全选" Style="{StaticResource PopupBtn}" Click="ThemeSelectAll_Click" />
                            <Button Content="取消全选" Style="{StaticResource PopupBtn}" Click="ThemeDeselectAll_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
